# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
APP_NAME=CRESCO Legal

# ─── JWT ───────────────────────────────────────────────
# Generate strong secrets:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORTAL_JWT_SECRET=change-me-portal-secret-min-32-chars

# ─── Database ──────────────────────────────────────────
# Ports below MATCH docker-compose.yml (remapped off the defaults so the
# stack doesn't collide with any Postgres/Redis/MinIO you already run).
DATABASE_URL=postgresql://clm:clm@localhost:5433/clm_dev
DATABASE_URL_TEST=postgresql://clm:clm@localhost:5433/clm_test

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Elasticsearch ─────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Storage (MinIO / S3) ──────────────────────────────
S3_ENDPOINT=http://localhost:9100
# Public URL browsers use for presigned downloads. Required in production when
# S3_ENDPOINT is localhost/internal; omit locally (API proxies downloads instead).
# S3_PUBLIC_ENDPOINT=https://contracts.example.com/storage
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clm-documents
S3_REGION=us-east-1

# ─── Gotenberg (document → PDF conversion) ─────────────
GOTENBERG_URL=http://localhost:3002

# ─── AI / Agents ───────────────────────────────────────
# Add AT LEAST ONE key to enable AI features. The app boots without any
# (you can browse, upload, and manage contracts) but the agent, extraction,
# and portfolio Q&A need a provider. Google has a generous free tier.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
AGENTS_URL=http://localhost:8000
INTERNAL_SERVICE_SECRET=change-me-internal-secret-min-32-chars

# BYOK encryption key — only needed if an org pastes its own provider key in
# the UI. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_KEY_ENCRYPTION_KEY=

# ─── Observability (optional) ──────────────────────────
# Langfuse LLM tracing. Leave blank to run without traces.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Email (optional) ──────────────────────────────────
# Outbound email uses SMTP (nodemailer). Email is ONLY sent when SMTP_HOST is
# set — leave it blank to run without email (signing links are still logged to
# the console and written to the DB). Any SMTP relay works: SendGrid, SES,
# Postmark, Mailgun, Gmail — point these at its SMTP endpoint.
SMTP_HOST=                       # e.g. smtp.sendgrid.net — the gate: unset = no email
SMTP_PORT=587                    # 587 (STARTTLS) or 465 (SMTPS, with SMTP_SECURE=true)
SMTP_SECURE=false                # true for port 465
SMTP_USER=                       # relay username (e.g. "apikey" for SendGrid)
SMTP_PASS=                       # relay password / API key — keep out of source control
SMTP_FROM=noreply@example.com    # From: address (falls back to EMAIL_FROM, then a default)
EMAIL_FROM=noreply@example.com   # legacy alias for SMTP_FROM; still honored

# Public base URL used to build signing links in emails (no trailing slash).
# Code falls back: WEB_BASE_URL → FRONTEND_URL → http://localhost:5173
WEB_BASE_URL=http://localhost:5173

# ─── Inbound email (optional) ──────────────────────────────────────────
# Lets a counterparty reply to a share email with a marked-up PDF/DOCX
# attached; it lands as a new version of that contract. Requires a provider
# inbound-parse webhook (SendGrid Inbound Parse, Mailgun Routes, Postmark)
# pointed at:  POST https://<your-api>/api/v1/inbound/email
# with MX records for the domain below pointed at that provider.
#
# INBOUND_EMAIL_DOMAIN — the domain the webhook receives mail for. Setting it
# turns on the "reply with your redline" invitation in outbound share emails
# (address form: contracts+<contractId>@<domain>). Leave blank to keep that
# invitation off, since nothing would be listening.
INBOUND_EMAIL_DOMAIN=
# Shared secret the provider must send as the x-inbound-secret header.
# REQUIRED in production — the endpoint returns 503 without it.
INBOUND_EMAIL_SECRET=
# Dev only: accept mail from ANY sender instead of just the contract's
# counterparty or an invited share-link address. Ignored in production.
INBOUND_EMAIL_ALLOW_ALL=

# ─── Feature flags ─────────────────────────────────────
ENABLE_SIGNUP=true
