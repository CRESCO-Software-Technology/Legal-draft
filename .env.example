# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Isolated secret for portal share link tokens (external reviewers)
PORTAL_JWT_SECRET=change-me-portal-secret-min-32-chars

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://clm:clm@localhost:5432/clm_dev
DATABASE_URL_TEST=postgresql://clm:clm@localhost:5432/clm_test

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ─────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Storage (MinIO / S3) ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clm-documents
S3_REGION=us-east-1

# ─── Gotenberg (document conversion) ──────────────────
GOTENBERG_URL=http://localhost:3002

# ─── AI / Agents ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
AGENTS_URL=http://localhost:8000
INTERNAL_SERVICE_SECRET=change-me-internal-secret-min-32-chars
# D.0.2 — BYOK encryption master key (32 bytes, base64). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required when any org pastes a BYOK API key on /admin/org > AI Config.
AI_KEY_ENCRYPTION_KEY=GENERATE_ME

# D.0.7 — Langfuse LLM observability. All three must be set to enable tracing;
# if any is blank the agents service still runs, just without traces. Grab keys
# from https://cloud.langfuse.com or your self-hosted instance.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Email (SendGrid) ──────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@yourapp.com

# ─── Feature flags ─────────────────────────────────────
ENABLE_SIGNUP=true
