# draftLegal self-host config — copy to `.env.selfhost` and fill in.
# Used by: docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up
#
# Generate strong secrets with: openssl rand -base64 48

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=clm
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=clm
# Must point at the `postgres` service on the internal network.
DATABASE_URL=postgresql://clm:CHANGE_ME_strong_db_password@postgres:5432/clm

# ── Redis ──────────────────────────────────────────────────────────────────
# Optional password; if set, include it in REDIS_URL below.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ── Object storage (MinIO) ─────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
S3_BUCKET=clm-documents

# ── App secrets (REQUIRED — the API refuses to boot without strong values) ──
# JWT_SECRET / PORTAL_JWT_SECRET must be >=32 chars and not a placeholder.
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_secret
PORTAL_JWT_SECRET=CHANGE_ME_another_32_plus_char_secret
INTERNAL_SERVICE_SECRET=CHANGE_ME_shared_api_agents_secret
# 32-byte key (base64) for encrypting per-org BYOK keys at rest. Optional
# unless orgs will store their own provider keys.
AI_KEY_ENCRYPTION_KEY=

# ── AI providers (at least one required for AI features) ────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Web ────────────────────────────────────────────────────────────────────
# Host port the SPA is served on. Build the web with VITE_API_URL=/api first:
#   VITE_API_URL=/api pnpm --filter web build
WEB_PORT=8080
