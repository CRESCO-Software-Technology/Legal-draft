# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Environment (keep tracked templates)
.env
.env.*
!.env.example

# Cloud Run env-vars files are tracked. They contain only non-secret
# config (URLs, feature flags). Real secrets come from Google Secret
# Manager via --set-secrets in scripts/deploy.sh.
# (env.api.yaml + env.agents.yaml are committed.)
# GitHub Actions deployer JSON key emitted by setup-github-deployer.sh —
# never commit this; it can deploy to prod.
github-deployer-key.json

# Firebase build artefacts / cache
.firebase/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Prisma
apps/api/prisma/migrations/*.lock

# Test coverage
coverage/
.nyc_output/

# Turbo
.turbo/

# TypeScript / lint caches
*.tsbuildinfo
.eslintcache

# Playwright
playwright-report/
test-results/
blob-report/

# Claude Code: ship shared skills + launch config; never commit worktrees or local permissions
.claude/worktrees/
.claude/settings.local.json

# Scripts: QA / audit / persona run output (large images; regenerate locally)
scripts/screenshots/
scripts/audit-screenshots/
scripts/persona-tests/output/

# UI smoke screenshots (regenerated each run)
scripts/screenshots/smoke-ui/

# Marketing assets — strategy/plans, not part of the product.
# Leading slash anchors to repo root so the tracked apps/marketing/ site is unaffected.
/marketing/

# Vite build cache
.vite/
apps/*/.vite/
